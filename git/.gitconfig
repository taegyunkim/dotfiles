[push]
	default = current
[core]
	excludesFile = ~/.gitignore
  ignorecase = false
[alias]
  tree = log --graph --decorate --pretty=oneline --abbrev-commit
[color]
	branch = auto
	diff = auto
	interactive = auto
	status = auto
[fetch]
	prune = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[diff]
  ignoreSubmodules = dirty
[pull]
  rebase = true
[init]
	defaultBranch = main
[user]
	name = Taegyun Kim
	email = k.taegyun@gmail.com

# Datadog overlay. Applies to:
#   - any repo (or worktree) whose `origin` URL is a DataDog GitHub repo.
# Requires git >= 2.36. See git/gitconfig-dd.
[includeIf "hasconfig:remote.*.url:git@github.com:DataDog/**"]
	path = ~/.dotfiles/git/gitconfig-dd
