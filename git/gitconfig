[push]
	default = current
[core]
	excludesFile = ~/.gitignore
  ignorecase = false
[alias]
  tree = log --graph --decorate --pretty=oneline --abbrev-commit
[color]
	branch = auto
	diff = auto
	interactive = auto
	status = auto
[fetch]
	prune = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[diff]
  ignoreSubmodules = dirty
[pull]
  rebase = true
[init]
	defaultBranch = main
[user]
	name = Taegyun Kim
	email = k.taegyun@gmail.com

# Datadog overlay: applies only to repos cloned under ~/dd/. Sets work
# email and SSH-key signing via dd-gitsign. See git/gitconfig-dd.
[includeIf "gitdir:~/dd/"]
	path = ~/.dotfiles/git/gitconfig-dd
